{
	"compilerOptions": {
		"target": "es2023",
		"module": "commonjs",
		"moduleResolution": "node",
		"outDir": "./dist",
		"strict": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"noImplicitAny": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true
	},
	"include": ["src/**/*.ts"],
	"exclude": ["node_modules", "dist"]
}
